#!/usr/bin/env python3
"""Vehicle-side V2V goal relay.

Subscribes to a target pose broadcast by the control station and forwards it
to Nav2 as a NavigateToPose goal. Both systems must share the same map frame
(the vehicle localizes against the same saved map the station is aligned to).

Input : /v2v/selected_target  (PoseStamped, map frame)
Action: navigate_to_pose      (nav2_msgs/action/NavigateToPose)

For a moving target the goal is re-sent (preempting the previous one) only
when the target has moved more than `update_dist` metres and at most every
`update_period` seconds, to avoid thrashing the planner.
"""
import math

import rclpy
from rclpy.node import Node
from rclpy.action import ActionClient
from geometry_msgs.msg import PoseStamped
from nav2_msgs.action import NavigateToPose


class GoalRelayNode(Node):
    def __init__(self):
        super().__init__('goal_relay_node')

        self.declare_parameter('target_topic', '/v2v/selected_target')
        self.declare_parameter('expected_frame', 'map')
        self.declare_parameter('update_dist', 0.5)     # m before re-sending goal
        self.declare_parameter('update_period', 1.0)   # s min between goals

        self.expected_frame = self.get_parameter('expected_frame').value
        self.update_dist = float(self.get_parameter('update_dist').value)
        self.update_period = float(self.get_parameter('update_period').value)

        self.last_goal_xy = None
        self.last_send_t = 0.0

        self.client = ActionClient(self, NavigateToPose, 'navigate_to_pose')
        self.create_subscription(
            PoseStamped, self.get_parameter('target_topic').value, self.target_cb, 5)

        self.get_logger().info('Goal relay ready (waiting for Nav2 navigate_to_pose action).')

    def target_cb(self, msg: PoseStamped):
        if msg.header.frame_id != self.expected_frame:
            self.get_logger().warn(
                f'Target frame "{msg.header.frame_id}" != expected "{self.expected_frame}"; '
                f'ignoring. Make sure the station publishes in the shared map frame.',
                throttle_duration_sec=5.0)
            return

        x, y = msg.pose.position.x, msg.pose.position.y
        now = self.get_clock().now().nanoseconds * 1e-9

        if self.last_goal_xy is not None:
            moved = math.hypot(x - self.last_goal_xy[0], y - self.last_goal_xy[1])
            if moved < self.update_dist and (now - self.last_send_t) < self.update_period:
                return

        if not self.client.server_is_ready():
            self.client.wait_for_server(timeout_sec=0.0)
            if not self.client.server_is_ready():
                self.get_logger().warn('Nav2 action server not available yet',
                                       throttle_duration_sec=5.0)
                return

        goal = NavigateToPose.Goal()
        goal.pose = msg
        self.client.send_goal_async(goal)
        self.last_goal_xy = (x, y)
        self.last_send_t = now
        self.get_logger().info(f'Sent Nav2 goal: ({x:.2f}, {y:.2f}) [{self.expected_frame}]')


def main(args=None):
    rclpy.init(args=args)
    node = GoalRelayNode()
    try:
        rclpy.spin(node)
    except KeyboardInterrupt:
        pass
    finally:
        node.destroy_node()
        rclpy.try_shutdown()


if __name__ == '__main__':
    main()
