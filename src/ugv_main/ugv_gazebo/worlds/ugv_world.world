      <link name="link"><visual name="visual"><cast_shadows>false</cast_shadows><geometry><box><size>6 6 0.02</size></box></geometry><material><ambient>0.2 0.2 0.2 1</ambient><diffuse>0.25 0.25 0.25 1</diffuse></material></visual></link>
