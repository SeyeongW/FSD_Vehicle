<?xml version="1.0" ?>
<sdf version="1.0">
  <world name="Mini_Airport_Clean">

    <plugin name="gazebo_ros_state" filename="libgazebo_ros_state.so">
      <ros>
        <namespace>/</namespace>
      </ros>
      <update_rate>20.0</update_rate>
    </plugin>

    <gravity>0 0 -9.8</gravity>
    <include><uri>model://sun</uri></include>

    <physics type="ode">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1.0</real_time_factor>
      <real_time_update_rate>1000</real_time_update_rate>
    </physics>

    <scene>
      <ambient>0.65 0.65 0.65 1</ambient>
      <background>0.68 0.83 1.0 1</background>
      <shadows>true</shadows>
    </scene>

    <!-- ========================================================= -->
    <!-- 1) BASE GROUND / BOUNDARY                                -->
    <!-- ========================================================= -->
    <model name="ground">
      <static>true</static>
      <pose>0 0 0 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>50 50 0.01</size></box></geometry>
        </collision>
        <visual name="visual">
          <cast_shadows>false</cast_shadows>
          <geometry><box><size>50 50 0.01</size></box></geometry>
          <material>
            <ambient>0.14 0.38 0.09 1</ambient>
            <diffuse>0.18 0.46 0.11 1</diffuse>
            <specular>0.01 0.01 0.01 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <model name="wall_north">
      <static>true</static>
      <pose>0 25 1.5 0 0 0</pose>
      <link name="link">
        <collision name="collision"><geometry><box><size>50 0.3 3</size></box></geometry></collision>
        <visual name="visual"><cast_shadows>false</cast_shadows><geometry><box><size>50 0.3 3</size></box></geometry>
          <material><ambient>0.52 0.50 0.46 1</ambient><diffuse>0.60 0.57 0.52 1</diffuse></material>
        </visual>
      </link>
    </model>
    <model name="wall_south">
      <static>true</static>
      <pose>0 -25 1.5 0 0 0</pose>
      <link name="link">
        <collision name="collision"><geometry><box><size>50 0.3 3</size></box></geometry></collision>
        <visual name="visual"><cast_shadows>false</cast_shadows><geometry><box><size>50 0.3 3</size></box></geometry>
          <material><ambient>0.52 0.50 0.46 1</ambient><diffuse>0.60 0.57 0.52 1</diffuse></material>
        </visual>
      </link>
    </model>
    <model name="wall_east">
      <static>true</static>
      <pose>25 0 1.5 0 0 0</pose>
      <link name="link">
        <collision name="collision"><geometry><box><size>0.3 50 3</size></box></geometry></collision>
        <visual name="visual"><cast_shadows>false</cast_shadows><geometry><box><size>0.3 50 3</size></box></geometry>
          <material><ambient>0.52 0.50 0.46 1</ambient><diffuse>0.60 0.57 0.52 1</diffuse></material>
        </visual>
      </link>
    </model>
    <model name="wall_west">
      <static>true</static>
      <pose>-25 0 1.5 0 0 0</pose>
      <link name="link">
        <collision name="collision"><geometry><box><size>0.3 50 3</size></box></geometry></collision>
        <visual name="visual"><cast_shadows>false</cast_shadows><geometry><box><size>0.3 50 3</size></box></geometry>
          <material><ambient>0.52 0.50 0.46 1</ambient><diffuse>0.60 0.57 0.52 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- ========================================================= -->
    <!-- 2) RUNWAY ZONE                                            -->
    <!-- ========================================================= -->
    <model name="runway_main">
      <static>true</static>
      <pose>0 -10.0 0.02 0 0 0</pose>
      <link name="link">
        <collision name="collision"><geometry><box><size>40 6 0.02</size></box></geometry></collision>
        <visual name="visual"><cast_shadows>false</cast_shadows><geometry><box><size>40 6 0.02</size></box></geometry>
          <material><ambient>0.03 0.03 0.03 1</ambient><diffuse>0.05 0.05 0.05 1</diffuse><specular>0 0 0 1</specular></material>
        </visual>
      </link>
    </model>

    <!-- runway centerline -->
    <model name="runway_center_1"><static>true</static><pose>-15 -10.0 0.031 0 0 0</pose><link name="link"><visual name="visual"><geometry><box><size>2.2 0.24 0.002</size></box></geometry><material><ambient>1 1 1 1</ambient><diffuse>1 1 1 1</diffuse></material></visual></link></model>
    <model name="runway_center_2"><static>true</static><pose>-10 -10.0 0.031 0 0 0</pose><link name="link"><visual name="visual"><geometry><box><size>2.2 0.24 0.002</size></box></geometry><material><ambient>1 1 1 1</ambient><diffuse>1 1 1 1</diffuse></material></visual></link></model>
    <model name="runway_center_3"><static>true</static><pose>-5 -10.0 0.031 0 0 0</pose><link name="link"><visual name="visual"><geometry><box><size>2.2 0.24 0.002</size></box></geometry><material><ambient>1 1 1 1</ambient><diffuse>1 1 1 1</diffuse></material></visual></link></model>
    <model name="runway_center_4"><static>true</static><pose>0 -10.0 0.031 0 0 0</pose><link name="link"><visual name="visual"><geometry><box><size>2.2 0.24 0.002</size></box></geometry><material><ambient>1 1 1 1</ambient><diffuse>1 1 1 1</diffuse></material></visual></link></model>
    <model name="runway_center_5"><static>true</static><pose>5 -10.0 0.031 0 0 0</pose><link name="link"><visual name="visual"><geometry><box><size>2.2 0.24 0.002</size></box></geometry><material><ambient>1 1 1 1</ambient><diffuse>1 1 1 1</diffuse></material></visual></link></model>
    <model name="runway_center_6"><static>true</static><pose>10 -10.0 0.031 0 0 0</pose><link name="link"><visual name="visual"><geometry><box><size>2.2 0.24 0.002</size></box></geometry><material><ambient>1 1 1 1</ambient><diffuse>1 1 1 1</diffuse></material></visual></link></model>
    <model name="runway_center_7"><static>true</static><pose>15 -10.0 0.031 0 0 0</pose><link name="link"><visual name="visual"><geometry><box><size>2.2 0.24 0.002</size></box></geometry><material><ambient>1 1 1 1</ambient><diffuse>1 1 1 1</diffuse></material></visual></link></model>

    <!-- threshold bars -->
    <model name="thr_l_1"><static>true</static><pose>-18.0 -9.0 0.031 0 0 0</pose><link name="link"><visual name="visual"><geometry><box><size>1.2 0.24 0.002</size></box></geometry><material><ambient>1 1 1 1</ambient></material></visual></link></model>
    <model name="thr_l_2"><static>true</static><pose>-18.0 -10.0 0.031 0 0 0</pose><link name="link"><visual name="visual"><geometry><box><size>1.2 0.24 0.002</size></box></geometry><material><ambient>1 1 1 1</ambient></material></visual></link></model>
    <model name="thr_l_3"><static>true</static><pose>-18.0 -11.0 0.031 0 0 0</pose><link name="link"><visual name="visual"><geometry><box><size>1.2 0.24 0.002</size></box></geometry><material><ambient>1 1 1 1</ambient></material></visual></link></model>
    <model name="thr_r_1"><static>true</static><pose>18.0 -9.0 0.031 0 0 0</pose><link name="link"><visual name="visual"><geometry><box><size>1.2 0.24 0.002</size></box></geometry><material><ambient>1 1 1 1</ambient></material></visual></link></model>
    <model name="thr_r_2"><static>true</static><pose>18.0 -10.0 0.031 0 0 0</pose><link name="link"><visual name="visual"><geometry><box><size>1.2 0.24 0.002</size></box></geometry><material><ambient>1 1 1 1</ambient></material></visual></link></model>
    <model name="thr_r_3"><static>true</static><pose>18.0 -11.0 0.031 0 0 0</pose><link name="link"><visual name="visual"><geometry><box><size>1.2 0.24 0.002</size></box></geometry><material><ambient>1 1 1 1</ambient></material></visual></link></model>

    <!-- runway edge lights -->
    <model name="light_r_1"><static>true</static><pose>-15 -13.2 0.10 0 0 0</pose><link name="link"><visual name="visual"><geometry><cylinder><radius>0.06</radius><length>0.2</length></cylinder></geometry><material><ambient>0.15 0.15 0.15 1</ambient><emissive>0.10 0.10 0.12 1</emissive></material></visual></link></model>
    <model name="light_r_2"><static>true</static><pose>-10 -13.2 0.10 0 0 0</pose><link name="link"><visual name="visual"><geometry><cylinder><radius>0.06</radius><length>0.2</length></cylinder></geometry><material><ambient>0.15 0.15 0.15 1</ambient><emissive>0.10 0.10 0.12 1</emissive></material></visual></link></model>
    <model name="light_r_3"><static>true</static><pose>-5 -13.2 0.10 0 0 0</pose><link name="link"><visual name="visual"><geometry><cylinder><radius>0.06</radius><length>0.2</length></cylinder></geometry><material><ambient>0.15 0.15 0.15 1</ambient><emissive>0.10 0.10 0.12 1</emissive></material></visual></link></model>
    <model name="light_r_4"><static>true</static><pose>0 -13.2 0.10 0 0 0</pose><link name="link"><visual name="visual"><geometry><cylinder><radius>0.06</radius><length>0.2</length></cylinder></geometry><material><ambient>0.15 0.15 0.15 1</ambient><emissive>0.10 0.10 0.12 1</emissive></material></visual></link></model>
    <model name="light_r_5"><static>true</static><pose>5 -13.2 0.10 0 0 0</pose><link name="link"><visual name="visual"><geometry><cylinder><radius>0.06</radius><length>0.2</length></cylinder></geometry><material><ambient>0.15 0.15 0.15 1</ambient><emissive>0.10 0.10 0.12 1</emissive></material></visual></link></model>
    <model name="light_r_6"><static>true</static><pose>10 -13.2 0.10 0 0 0</pose><link name="link"><visual name="visual"><geometry><cylinder><radius>0.06</radius><length>0.2</length></cylinder></geometry><material><ambient>0.15 0.15 0.15 1</ambient><emissive>0.10 0.10 0.12 1</emissive></material></visual></link></model>
    <model name="light_r_7"><static>true</static><pose>15 -13.2 0.10 0 0 0</pose><link name="link"><visual name="visual"><geometry><cylinder><radius>0.06</radius><length>0.2</length></cylinder></geometry><material><ambient>0.15 0.15 0.15 1</ambient><emissive>0.10 0.10 0.12 1</emissive></material></visual></link></model>

    <model name="light_l_1"><static>true</static><pose>-15 -6.8 0.10 0 0 0</pose><link name="link"><visual name="visual"><geometry><cylinder><radius>0.06</radius><length>0.2</length></cylinder></geometry><material><ambient>0.15 0.15 0.15 1</ambient><emissive>0.10 0.10 0.12 1</emissive></material></visual></link></model>
    <model name="light_l_2"><static>true</static><pose>-10 -6.8 0.10 0 0 0</pose><link name="link"><visual name="visual"><geometry><cylinder><radius>0.06</radius><length>0.2</length></cylinder></geometry><material><ambient>0.15 0.15 0.15 1</ambient><emissive>0.10 0.10 0.12 1</emissive></material></visual></link></model>
    <model name="light_l_3"><static>true</static><pose>-5 -6.8 0.10 0 0 0</pose><link name="link"><visual name="visual"><geometry><cylinder><radius>0.06</radius><length>0.2</length></cylinder></geometry><material><ambient>0.15 0.15 0.15 1</ambient><emissive>0.10 0.10 0.12 1</emissive></material></visual></link></model>
    <model name="light_l_4"><static>true</static><pose>0 -6.8 0.10 0 0 0</pose><link name="link"><visual name="visual"><geometry><cylinder><radius>0.06</radius><length>0.2</length></cylinder></geometry><material><ambient>0.15 0.15 0.15 1</ambient><emissive>0.10 0.10 0.12 1</emissive></material></visual></link></model>
    <model name="light_l_5"><static>true</static><pose>5 -6.8 0.10 0 0 0</pose><link name="link"><visual name="visual"><geometry><cylinder><radius>0.06</radius><length>0.2</length></cylinder></geometry><material><ambient>0.15 0.15 0.15 1</ambient><emissive>0.10 0.10 0.12 1</emissive></material></visual></link></model>
    <model name="light_l_6"><static>true</static><pose>10 -6.8 0.10 0 0 0</pose><link name="link"><visual name="visual"><geometry><cylinder><radius>0.06</radius><length>0.2</length></cylinder></geometry><material><ambient>0.15 0.15 0.15 1</ambient><emissive>0.10 0.10 0.12 1</emissive></material></visual></link></model>
    <model name="light_l_7"><static>true</static><pose>15 -6.8 0.10 0 0 0</pose><link name="link"><visual name="visual"><geometry><cylinder><radius>0.06</radius><length>0.2</length></cylinder></geometry><material><ambient>0.15 0.15 0.15 1</ambient><emissive>0.10 0.10 0.12 1</emissive></material></visual></link></model>

    <!-- ========================================================= -->
    <!-- 4) APRON + TERMINAL                                       -->
    <!-- ========================================================= -->
    <model name="apron">
      <static>true</static>
      <pose>12.0 13.0 0.02 0 0 0</pose>
      <link name="link">
        <collision name="collision"><geometry><box><size>18 10 0.02</size></box></geometry></collision>
        <visual name="visual"><cast_shadows>false</cast_shadows><geometry><box><size>18 10 0.02</size></box></geometry>
          <material><ambient>0.42 0.42 0.42 1</ambient><diffuse>0.52 0.52 0.52 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- parking stand markings -->
    <model name="stand_line_1"><static>true</static><pose>7.5 12.2 0.031 0 0 1.57079632679</pose><link name="link"><visual name="visual"><geometry><box><size>4.5 0.12 0.002</size></box></geometry><material><ambient>1 0.95 0.35 1</ambient></material></visual></link></model>
    <model name="stand_line_2"><static>true</static><pose>12.0 12.2 0.031 0 0 1.57079632679</pose><link name="link"><visual name="visual"><geometry><box><size>4.5 0.12 0.002</size></box></geometry><material><ambient>1 0.95 0.35 1</ambient></material></visual></link></model>
    <model name="stand_line_3"><static>true</static><pose>16.5 12.2 0.031 0 0 1.57079632679</pose><link name="link"><visual name="visual"><geometry><box><size>4.5 0.12 0.002</size></box></geometry><material><ambient>1 0.95 0.35 1</ambient></material></visual></link></model>
    <model name="stand_stop_1"><static>true</static><pose>7.5 14.0 0.031 0 0 0</pose><link name="link"><visual name="visual"><geometry><box><size>1.4 0.12 0.002</size></box></geometry><material><ambient>1 0.95 0.35 1</ambient></material></visual></link></model>
    <model name="stand_stop_2"><static>true</static><pose>12.0 14.0 0.031 0 0 0</pose><link name="link"><visual name="visual"><geometry><box><size>1.4 0.12 0.002</size></box></geometry><material><ambient>1 0.95 0.35 1</ambient></material></visual></link></model>
