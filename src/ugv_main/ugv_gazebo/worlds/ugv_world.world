    <!-- radar -->
    <model name="radar_tower"><static>true</static><pose>11.0 -17.0 1.5 0 0 0</pose><link name="link"><visual name="visual"><geometry><cylinder><radius>0.6</radius><length>3.0</length></cylinder></geometry><material><ambient>0.6 0.6 0.6 1</ambient></material></visual></link></model>
    <model name="radar_dome"><static>true</static><pose>11.0 -17.0 3.0 0 0 0</pose><link name="link"><visual name="visual"><geometry><sphere><radius>1.2</radius></sphere></geometry><material><ambient>0.9 0.9 0.9 1</ambient></material></visual></link></model>

    <model name="fuel_1"><static>true</static><pose>-5.0 2.5 0.10 0 0 0</pose><link name="link"><visual name="visual"><geometry><cylinder><radius>0.2</radius><length>1.0</length></cylinder></geometry><material><ambient>0.15 0.15 0.15 1</ambient><emissive>0.10 0.10 0.12 1</emissive></material></visual></link></model>
    <model name="fuel_2"><static>true</static><pose>-5.0 2.9 0.10 0 0 0</pose><link name="link"><visual name="visual"><geometry><cylinder><radius>0.2</radius><length>1.0</length></cylinder></geometry><material><ambient>0.15 0.15 0.15 1</ambient><emissive>0.10 0.10 0.12 1</emissive></material></visual></link></model>
    <model name="fuel_3"><static>true</static><pose>-5.4 2.7 0.10 0 0 0</pose><link name="link"><visual name="visual"><geometry><cylinder><radius>0.2</radius><length>1.0</length></cylinder></geometry><material><ambient>0.15 0.15 0.15 1</ambient><emissive>0.10 0.10 0.12 1</emissive></material></visual></link></model>
    <model name="fuel_4"><static>true</static><pose>-5.15 2.7 0.85 0 0 0</pose><link name="link"><visual name="visual"><geometry><cylinder><radius>0.2</radius><length>0.5</length></cylinder></geometry><material><ambient>0.15 0.15 0.15 1</ambient><emissive>0.10 0.10 0.12 1</emissive></material></visual></link></model>

    <!-- ========================================================= -->
    <!-- 6) CESSNA : model:// URI 방식 (GAZEBO_MODEL_PATH 필요)   -->
    <!--    apron stand 1번 위치에 주기, 터미널 방향(y+) 정렬     -->
    <!-- ========================================================= -->
    <include>
      <uri>model://cessna</uri>
      <name>cessna_1</name>
      <pose>12.0 13.0 0.5 0 0 1.5707963</pose>
      <static>true</static>
    </include>

    <!-- ========================================================= -->
    <!-- 7) BUS : model:// URI 방식 (GAZEBO_MODEL_PATH 필요)      -->
    <!--    서비스 도로 위 주차, x축 방향 정렬                    -->
    <!-- ========================================================= -->
    <include>
      <uri>model://bus</uri>
      <name>bus_1</name>
      <pose>0.0 14.0 0.1 0 0 0</pose>
      <static>true</static>
    </include>
    
    <include>
      <uri>model://cessna</uri>
      <name>cessna_2</name>
      <pose>-14.0 -10.0 0.5 0 0 0</pose>
      <static>true</static>
    </include>
    
    <include>
      <uri>model://quadrotor</uri>
      <name>quadrotor_1</name>
      <pose>17.0 -17.0 0.1 0 0 0</pose>
      <static>true</static>
    </include>

  </world>
</sdf>
