      <static>true</static>
      <pose>12.0 20.0 1.85 0 0 0</pose>
      <link name="link">
        <collision name="collision"><geometry><box><size>16 4.5 3.7</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>16 4.5 3.7</size></box></geometry>
          <material><ambient>0.72 0.78 0.84 1</ambient><diffuse>0.78 0.84 0.90 1</diffuse></material>
