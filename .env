# ==============================================
# FSD_Vehicle Docker 환경변수 (Project Root)
# ==============================================

# 프로젝트 고유 이름 (Docker Network/Project)
COMPOSE_PROJECT_NAME=fsd_vehicle

# 이미지 및 컨테이너 이름
IMAGE_NAME=fsd-vehicle
CONTAINER_NAME=fsd_dev

# 로봇 모델 선택: ugv_rover / ugv_beast / rasp_rover
UGV_MODEL=ugv_rover

# 하드웨어 장치 설정 (실제 로봇 연결 시)
SERIAL_PORT_JETSON=/dev/ttyTHS1
SERIAL_PORT_PC=/dev/ttyUSB0
VIDEO_DEVICE=/dev/video0

# ROS Domain ID
ROS_DOMAIN_ID=0

# ── 워크스페이스 경로 ──────────────────────────────────
# 로컬 실행 시: 자신의 워크스페이스 절대경로로 수정하세요
# Docker 실행 시: docker-compose에서 자동으로 /ros2_ws/ugv_ws 로 설정됨
# 또는 source setup_local_env.sh 하면 자동 감지됩니다
UGV_WS_PATH=/ros2_ws/ugv_ws
